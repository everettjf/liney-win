{
  "shell": "cmd.exe",
  "fontFamily": "Cascadia Mono",
  "fontSize": 16,
  "scrollback": 10000,
  "workspaceRoot": "",
  "unixTools": true,
  "copyOnSelect": false,

  "hooks": {
    "sessionStart": "",
    "sessionExit": "",
    "appExit": ""
  },

  "sshHosts": [
    "user@example.com"
  ],

  "agents": [
    { "name": "my-agent", "command": "claude", "cwd": "" }
  ],

  "projectIcons": {
    "my-repo": "C:\\path\\to\\icon.png"
  },

  "theme": {
    "background": "#102840",
    "foreground": "#e8e8d0",
    "palette": [
      "#000000", "#cd0000", "#00cd00", "#cdcd00",
      "#0000ee", "#cd00cd", "#00cdcd", "#e5e5e5",
      "#7f7f7f", "#ff0000", "#00ff00", "#ffff00",
      "#5c5cff", "#ff00ff", "#00ffff", "#ffffff"
    ]
  }
}
